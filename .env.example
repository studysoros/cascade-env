# Cascade environment variables
# Copy to `.env` and fill in values as needed:
#   cp .env.example .env   # bash
#   Copy-Item .env.example .env  # PowerShell
#
# `.env` is gitignored. Do not commit real vendor secrets.

# ---------------------------------------------------------------------------
# Local HTTP rollout server (cascade serve)
# Any string you invent — NOT a cloud/vendor API key.
# ---------------------------------------------------------------------------
CASCADE_SERVER_API_KEY=dev-key
# CASCADE_SERVER_HOST=127.0.0.1
# CASCADE_SERVER_PORT=8765
# CASCADE_ENABLE_HTTP_SERVER=false
# CASCADE_MAX_PARALLEL_EPISODES=1

# ---------------------------------------------------------------------------
# Runtime / packs (optional)
# ---------------------------------------------------------------------------
# CASCADE_RUNTIME=local
# CASCADE_HOLDOUT_DIR=
# CASCADE_EXTRA_PACKS=

# ---------------------------------------------------------------------------
# Real model as the agent (optional)
# Only needed for --agent llm / examples/llm_tool_loop.py / eval-baselines --agent llm.
# Scripted episodes need none of these.
# Set ONE provider key (or CASCADE_LLM_API_KEY).
# ---------------------------------------------------------------------------
# XAI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# CASCADE_LLM_API_KEY=
# CASCADE_LLM_PROVIDER=xai
# CASCADE_LLM_MODEL=grok-3
# CASCADE_LLM_BASE_URL=
